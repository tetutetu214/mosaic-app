        <mxCell id="lg-7-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;画像の入出力 (S3)&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;LINE Content API で取得した原画像を S3 に保存し、結果画像も S3 に書き戻す&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="lg-7">
          <mxGeometry x="52" width="548" height="60" as="geometry" />
        </mxCell>

        <!-- Legend step 8 -->
        <mxCell id="lg-8" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry y="490" width="600" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lg-8-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="8" vertex="1" parent="lg-8">
          <mxGeometry y="2" width="40" height="38" as="geometry" />
