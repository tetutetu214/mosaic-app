        <mxCell id="lg-8-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;顔検出と照合&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Rekognition の DetectFaces と SearchFacesByImage で登録済み顔以外をモザイク化&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="lg-8">
          <mxGeometry x="52" width="548" height="60" as="geometry" />
