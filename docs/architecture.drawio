        </mxCell>
        <mxCell id="lg-2-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;handler Lambda 起動&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;API Gateway が Lambda Proxy で handler を呼び出す&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="lg-2">
          <mxGeometry x="52" width="548" height="60" as="geometry" />
        </mxCell>

