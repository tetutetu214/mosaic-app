          <mxGeometry y="2" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="lg-5-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;SQS にエンキュー&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;userId/messageId/replyToken を SQS に投入し API Gateway に 200 即返却&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="lg-5">
          <mxGeometry x="52" width="548" height="60" as="geometry" />
        </mxCell>

