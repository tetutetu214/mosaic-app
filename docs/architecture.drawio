          <mxGeometry x="630" y="430" width="28" height="28" as="geometry" />
        </mxCell>

        <!-- Edge 6: SQS → processor (event source) -->
        <mxCell id="edge-6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#545B64;endArrow=block;endFill=1;" edge="1" parent="1" source="svc-sqs" target="svc-processor">
